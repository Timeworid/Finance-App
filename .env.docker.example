# Variables d'environnement pour Docker Compose
# ⚠️  COPIEZ CE FICHIER VERS .env.docker ET CONFIGUREZ VOS VALEURS!
# cp .env.docker.example .env.docker

# ========================================
# MongoDB Configuration
# ========================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_root_password_secure_REPLACE_THIS
MONGO_APP_PASSWORD=changeme_app_password_secure_REPLACE_THIS

# ========================================
# JWT Secrets (GÉNÉRER DE NOUVEAUX SECRETS!)
# ========================================
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=YOUR_JWT_SECRET_HERE_64_BYTES_HEX_REPLACE_THIS
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_HERE_64_BYTES_HEX_REPLACE_THIS

# ========================================
# Encryption Key (GÉNÉRER UNE NOUVELLE CLÉ!)
# ========================================
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE_32_BYTES_HEX_REPLACE_THIS

# ========================================
# URLs et Domaines
# ========================================

# URL du frontend (modifier avec votre domaine en production)
FRONTEND_URL=http://localhost:3000

# URL de l'API pour le frontend (Vite)
VITE_API_URL=http://localhost:5000/api

# URL du backend pour Nginx (interne Docker)
BACKEND_URL=http://backend:5000

# ========================================
# Configuration Production (optionnel)
# ========================================

# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info

# Node environment
NODE_ENV=production
