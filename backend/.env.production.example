# Production Environment Variables
# ⚠️  IMPORTANT: Générez de nouveaux secrets pour la production !

# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://votre-domaine.com

# MongoDB (MongoDB Atlas recommandé)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/financepilot?retryWrites=true&w=majority

# JWT Secrets (GÉNÉRER DE NOUVEAUX SECRETS!)
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_SECRET_64_BYTES_HEX
JWT_REFRESH_SECRET=REMPLACER_PAR_SECRET_64_BYTES_HEX

# Encryption (GÉNÉRER UNE NOUVELLE CLÉ!)
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REMPLACER_PAR_CLE_32_BYTES_HEX

# Rate Limiting (ajusté pour production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS
CORS_ORIGIN=https://votre-domaine.com

# Session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
